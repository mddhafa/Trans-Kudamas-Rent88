# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Environment variables
.env
.env.local
.env.*.local
!.env.example

# Credentials & keys
.git-credentials
.npmrc
*.pem
*.key
*.p12

# OS files
Thumbs.db
.DS_Store
.AppleDouble
.LSOverride

# IDE cache
.eslintcache

# Build & dist cache
dist/
.cache/
.turbo/

# Package manager
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
pnpm-lock.yaml

# Temporary files
tmp/
temp/
*.tmp

# Public uploads (if any)
public/uploads/
public/static/uploads/
