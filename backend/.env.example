# Database Connection
# Format: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://username:password@localhost:5432/agilrentstravel_db?schema=public"

# JWT Secret for token signing
# Use a strong, random key (minimum 32 bytes, recommended 64)
# Generate with: openssl rand -hex 64
JWT_SECRET="your-super-secret-jwt-key-here"

# Admin WhatsApp Number
# Format: +62... (with country code)
NO_WA_ADMIN="+62123456789"

# Node Environment
NODE_ENV="development"

# Server Port (optional)
PORT="3001"
